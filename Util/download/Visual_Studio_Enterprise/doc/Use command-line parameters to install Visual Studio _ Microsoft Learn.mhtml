<thead>
<tr>
<th><strong>Edition</strong></th>
<th><strong>Bootstrapper</strong></th>
</tr>
</thead>
<tbody>
<tr>
<td>Visual Studio 2022 Enterprise</td>
<td><a href=3D"https://aka.ms/vs/17/release/vs_enterprise.exe" data-linktyp=
e=3D"external">vs_enterprise.exe</a></td>
</tr>
